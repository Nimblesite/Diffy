{
  "manifestVersion": 1,
  "product": {
    "id": "diffly",
    "displayName": "Diffly",
    "version": "0.1.0",
    "repository": "https://github.com/Nimblesite/Diffly",
    "homepage": "https://github.com/Nimblesite/Diffly"
  },
  "components": [
    {
      "id": "diffly-vscode",
      "kind": "extension-vscode",
      "language": "typescript",
      "expectedVersion": "${PRODUCT_VERSION}",
      "platforms": ["all"]
    }
  ],
  "hosts": {
    "vscode": {
      "artifact": "vsix-fat",
      "onMismatch": "error"
    }
  }
}
